Phase: Remove
Input: exposure
Options: control = all

Rule: removeFinalDrugs
(
{exposure}
):fh
-->
{
AnnotationSet tdset = (AnnotationSet)bindings.get("fh");
if(tdset != null){
AnnotationSet totalset = inputAS.getContained(tdset.firstNode().getOffset(),tdset.lastNode().getOffset());
AnnotationSet exposure = totalset.get("exposure");
inputAS.removeAll(totalset);
if (exposure != null && !exposure.isEmpty()){
ArrayList flist = new ArrayList(exposure);
Collections.sort(flist,new OffsetComparator());
for(Iterator occuranceIterator = flist.iterator();occuranceIterator.hasNext();)
{
Annotation occuranceAnn = (Annotation)occuranceIterator.next();
gate.FeatureMap features = occuranceAnn.getFeatures();
outputAS.add(occuranceAnn.getStartNode(),occuranceAnn.getEndNode(),"exposure",features);
}
}
}
}

