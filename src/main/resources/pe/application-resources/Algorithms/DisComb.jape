Collections.sort(flist,new OffsetComparator());
for(Iterator occuranceIterator = flist.iterator();occuranceIterator.hasNext();)
{
Annotation occuranceAnn = (Annotation)occuranceIterator.next();
gate.FeatureMap features = occuranceAnn.getFeatures();
outputAS.add(occuranceAnn.getStartNode(),occuranceAnn.getEndNode(),"drug",features);
}
}
}
}

Phase: SectionEnd
Input: Token drug exposure
Options: control = appelt

Rule: comb
(
(
({exposure})
({Token, Token.string != ".", Token.string != "-"})[0,10]
({drug})
)|
(
({drug})
({Token, Token.string != ".", Token.string != "-"})[0,10]
({exposure})
)
):line
-->
:line.tempe = {Rule = "comb111", Text = :line@cleanString, exposure = :line.exposure.Text, drug = :line.drug.Text}


Rule:comb3	/* Has received at least 2 consecutive cycles of a proteasome inhibitor (PI).*/
(
({exposure})
({Token, Token.string != "-"})[0,8]
(
({drug})
({Token, Token.string != "-"})[0,6]
)[1,8]
):Primary
-->
{
String mydocContent=doc.getContent().toString();
AnnotationSet disease = (AnnotationSet)bindings.get("Primary");
AnnotationSet siteSet = disease.get("drug");

AnnotationSet disorderSet = disease.get("exposure");
Annotation disorderAnn =(Annotation)disorderSet.iterator().next();	
String exposure = (String)disorderAnn.getFeatures().get("Text");

ArrayList disList = new ArrayList(siteSet);
Collections.sort(disList, new OffsetComparator());
for(Iterator iterator = disList.iterator();iterator.hasNext();)
{
gate.FeatureMap features = Factory.newFeatureMap(); 
Annotation diseaseAnn =(Annotation)iterator.next();
int cstartPos = (int)diseaseAnn.getStartNode().getOffset().longValue();    
int cendPos = (int)diseaseAnn.getEndNode().getOffset().longValue();
String content = mydocContent.substring(cstartPos,cendPos);
String drug = (String)diseaseAnn.getFeatures().get("Text");


features.put("Rule","comb321");
features.put("drug",drug);
features.put("exposure",exposure);
outputAS.add(diseaseAnn.getStartNode(),diseaseAnn.getEndNode(),"tempe",features);
}
}

