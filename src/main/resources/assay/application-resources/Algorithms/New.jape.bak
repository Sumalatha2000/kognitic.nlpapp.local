Phase: OriginalMarkupTrailcriteria5
Input: BioMarker Token
Options: control = brill

Rule: SectionHigh5
(
({Token})[75]
({BioMarker}):content
({Token})[75]
):sample
-->
{
String mydocContent = doc.getContent().toString();
AnnotationSet all = (AnnotationSet)bindings.get("sample");
int cstartpos = (int)all.firstNode().getOffset().longValue();
int cend = (int)all.lastNode().getOffset().longValue();
String sentence9 = mydocContent.substring(cstartpos,cend);
gate.FeatureMap features = Factory.newFeatureMap();

AnnotationSet matchedAnns = bindings.get("content");
int begOffset = matchedAnns.firstNode().getOffset().intValue();
int endOffset = matchedAnns.lastNode().getOffset().intValue();
String mydocContent1 = doc.getContent().toString();
String matchedString = mydocContent1.substring(begOffset, endOffset);

features.put("Sentence", sentence9);
features.put("Biomarker", matchedString);
outputAS.add(all.firstNode(),all.lastNode(),"FinalBioAssay", features);
}

Phase: OriginalMarkupTrailcriteria6
Input: FinalBioAssay SectionAssayTest
Options: control = brill

Rule: SectionHigh5
(
({SectionAssayTest within FinalBioAssay})
):sample
-->
{
AnnotationSet units  = (AnnotationSet)bindings.get("sample");
AnnotationSet UnitSet = (AnnotationSet)units.get("SectionAssayTest");

AnnotationSet allSet = inputAS.get(gate.Utils.start(UnitSet),gate.Utils.end(UnitSet));
AnnotationSet SAset = allSet.get("FinalBioAssay");
Annotation SAann = (gate.Annotation)SAset.iterator().next();
String MatchedSent = (String)SAann.getFeatures().get("Sentence");
Annotation Bann = (gate.Annotation)SAset.iterator().next();
String Biomarker = (String)Bann.getFeatures().get("Biomarker");



ArrayList ulist = new ArrayList(UnitSet);
Collections.sort(ulist,new OffsetComparator());
for(Iterator iterator = ulist.iterator();iterator.hasNext();)
{
Annotation unitAnn = (Annotation)iterator.next();
gate.FeatureMap features = unitAnn.getFeatures();
/*features.put("Sentence", MatchedSent);*/
features.put("Biomarker", Biomarker);
outputAS.add(unitAnn.getStartNode(),unitAnn.getEndNode(),"FinalAssay",features);
}
}

