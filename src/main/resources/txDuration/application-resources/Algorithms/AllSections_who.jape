Phase: OriginalMarkupTrailcriteria9
Input: Condition therapy
Options: control = appelt

Rule: SectionHigh12
(
({therapy within Condition})
):sample
-->
{
AnnotationSet units  = (AnnotationSet)bindings.get("sample");
int cstartpos = (int)units.firstNode().getOffset().longValue();
int cend = (int)units.lastNode().getOffset().longValue();

AnnotationSet UnitSet = (AnnotationSet)units.get("therapy");
gate.FeatureMap features = Factory.newFeatureMap();


Annotation headann = (gate.Annotation)UnitSet.iterator().next();
String FinalText = (String)headann.getFeatures().get("Text");
String Disease = (String)headann.getFeatures().get("Disease");
String Site = (String)headann.getFeatures().get("Site");
String Site2 = (String)headann.getFeatures().get("Site2");
String Tconcept = (String)headann.getFeatures().get("Tconcept");
String Population = (String)headann.getFeatures().get("Population");

features.put("Text",FinalText);
features.put("Disease",Disease);
features.put("Site",Site);
features.put("Site2",Site2);
features.put("Section","Condition");
features.put("Rule","SectionHigh12");
features.put("Finding","Positive");
features.put("Tconcept",Tconcept);
features.put("Population",Population);

outputAS.add(units.firstNode(),units.lastNode(),"Finaltherapy", features);
}


