Phase: AlldataPoints
Input: Sentence1 SectionHeadings
Options: control = appelt

Rule: PSNo
 
({SectionHeadings.Text == "Report Date"}({SectionHeadings.Text == "Visit Date (s)"}|{SectionHeadings.Text == "Visit Date"}|{SectionHeadings.Text == "Visit Date(s)"}){SectionHeadings.Text == "Prior Visit Date"})
(
({Sentence1})[1,4]
):studyno

-->  
{

AnnotationSet all = (AnnotationSet)bindings.get("studyno");
FeatureMap newFeatures = Factory.newFeatureMap();

AnnotationSet headset = all.get("Sentence1");
ArrayList packList = new ArrayList (headset);
Collections.sort (packList, new OffsetComparator());
for(int i=0;i<packList.size();i++)
{

	switch(i)
	{
	 case 0:Annotation packAnn=(Annotation)packList.get(i);
			newFeatures.put("monitor",(String)packAnn.getFeatures().get("Name"));
	 case 1:Annotation packAnn1=(Annotation)packList.get(i);
			newFeatures.put("reportdate",(String)packAnn1.getFeatures().get("Name"));
	 case 2:Annotation packAnn2=(Annotation)packList.get(i);
			newFeatures.put("visitdata",(String)packAnn2.getFeatures().get("Name"));
	 case 3:Annotation packAnn3=(Annotation)packList.get(i);
			newFeatures.put("pvisitdata",(String)packAnn3.getFeatures().get("Name"));
	}
}
outputAS.add(all.firstNode(), all.lastNode(),"MetaData", newFeatures);
}

Rule: PSNo2
 
({SectionHeadings.Text == "Study Number"}{SectionHeadings.Text == "Investigator Name"}{SectionHeadings.Text == "Site Number"})
