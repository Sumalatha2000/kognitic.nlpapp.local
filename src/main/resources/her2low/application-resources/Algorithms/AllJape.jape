Rule: TableDetectionRule
(
{FinalSubsecContent}
):TargetTable
-->
{  
String mydocContent1 = doc.getContent().toString();
AnnotationSet contentSet = (gate.AnnotationSet)bindings.get("TargetTable");
AnnotationSet tableAnnotationSet = inputAS.get("table").getContained(contentSet.firstNode().getOffset(), contentSet.lastNode().getOffset());
gate.FeatureMap features = Factory.newFeatureMap();

if (tableAnnotationSet != null && !tableAnnotationSet.isEmpty())
{

AnnotationSet allunits  = (AnnotationSet)bindings.get("TargetTable");
AnnotationSet allSet = (AnnotationSet)allunits.get("FinalSubsecContent");
ArrayList alllist = new ArrayList(allSet);
Collections.sort(alllist,new OffsetComparator());
for(Iterator iterator = alllist.iterator();iterator.hasNext();)
{
Annotation allAnn = (Annotation)iterator.next();
gate.FeatureMap newfeatures = allAnn.getFeatures();
features.putAll(allAnn.getFeatures()); 
}

 ArrayList tableList=new ArrayList(tableAnnotationSet);
 Collections.sort(tableList, new OffsetComparator());
 String temp="";
 for(int k=0;k<tableList.size();k++)
{
StringJoiner sjtable=new StringJoiner("","<table border='1'>","</table>");
 String text="" ,text1="",text2="";
Annotation tableAnnotation=null;
Annotation tableAnnotation1=null;
if(k<tableList.size()-1)
{
 tableAnnotation=(Annotation)tableList.get(k);
 tableAnnotation1=(Annotation)tableList.get(k+1);
 text1=mydocContent1.substring(tableAnnotation.getEndNode().getOffset().intValue(),tableAnnotation1.getStartNode().getOffset().intValue());
 
}
else
