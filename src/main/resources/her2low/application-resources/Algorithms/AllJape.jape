Phase: MainSectionContent
Input: Token FinalHeadings SubSectionHeading MainSectionHighlights FinalHeading
Options: control = appelt

Rule: seccon
(
(({FinalHeadings})):fh
(({Token})*):content
(({SubSectionHeading})|({FinalHeading}))?
):sample
-->
{
String mydocContent = doc.getContent().toString();
AnnotationSet all = (AnnotationSet)bindings.get("sample");
int cstartpos = (int)all.firstNode().getOffset().longValue();
int cend = (int)all.lastNode().getOffset().longValue();
String sentence9 = mydocContent.substring(cstartpos,cend);
String actualheading = "";
gate.FeatureMap features = Factory.newFeatureMap();
AnnotationSet headset = all.get("FinalHeadings");
Annotation headann = (gate.Annotation)headset.iterator().next();
String heading = (String)headann.getFeatures().get("Heading");
actualheading = (String)headann.getFeatures().get("ActualHeading");
actualheading = actualheading.trim();
String sId = (String)headann.getFeatures().get("SectionId");

AnnotationSet matchedAnns = bindings.get("content");
String matchedString = "";
if(matchedAnns != null){
int begOffset = matchedAnns.firstNode().getOffset().intValue();
int endOffset = matchedAnns.lastNode().getOffset().intValue();
String mydocContent1 = doc.getContent().toString();
matchedString = mydocContent1.substring(begOffset, endOffset);
}
else{
matchedString = "";
}

AnnotationSet allanot = doc.getAnnotations();
AnnotationSet mainsecset = allanot.get("MainSectionHighlights");
Annotation mainsecann = (gate.Annotation)mainsecset.iterator().next();
ArrayList highlist = new ArrayList(mainsecset);
Collections.sort(highlist, new OffsetComparator());
for(Iterator iterator = highlist.iterator();iterator.hasNext();){
Annotation occuranceAnn = (Annotation)iterator.next();
gate.FeatureMap oldfeatures = occuranceAnn.getFeatures();
String high = (String)oldfeatures.get("Content");
high = high.replace("-","");
String highlitheading = (String)oldfeatures.get("MSHeading");
highlitheading = highlitheading.replace("-","");
highlitheading = highlitheading.trim();
if(highlitheading.equalsIgnoreCase(actualheading)){
features.put("Highlights", high);
}
}

features.put("Text", matchedString);
features.put("Heading", heading);
features.put("SectionId", sId);
features.put("ActualHeading", actualheading);
outputAS.add(all.firstNode(),all.lastNode(),"MSContent", features);
}


