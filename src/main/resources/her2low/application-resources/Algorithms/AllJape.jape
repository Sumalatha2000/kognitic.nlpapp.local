	 case 2:Annotation packAnn2=(Annotation)packList.get(i);
			newFeatures.put("siteno",(String)packAnn2.getFeatures().get("Name"));

	}
}
outputAS.add(all.firstNode(), all.lastNode(),"MetaData2", newFeatures);
