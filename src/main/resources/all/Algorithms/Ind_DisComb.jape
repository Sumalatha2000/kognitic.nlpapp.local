Rule:comb5	/*  adenocarcinoma of the thoracic esophagus or (EndOfLine)gastroesophageal junction*/
(
	{Disease, Disease.Disease != "tumor"}
	({Comb})?
	({Token})?
  (({Site})
  ({Token.string ==~ "(?i)or"})?
  ({EndOfLine})?  
  )[1,10]
  
 ):Primary
-->
