Phase: SectionEnd123
Input: Token
Options: control = appelt
Rule: endline
(
({Token.string == "L"}{Token.string == "19"}{Token.string == "TNFα"}):line
)
-->
:line.RemoveToken = {Rule = "endline"}

Phase: SectionEnd1234
Input: RemoveToken
Options: control = appelt
Rule: removebreakline
(
{RemoveToken}
):fh
-->
{
AnnotationSet tdset = (AnnotationSet)bindings.get("fh");
if(tdset != null){
AnnotationSet totalset = inputAS.getContained(tdset.firstNode().getOffset(),tdset.lastNode().getOffset());
AnnotationSet RemoveToken = totalset.get("RemoveToken");
inputAS.removeAll(totalset);
if (RemoveToken != null && !RemoveToken.isEmpty()){
ArrayList flist = new ArrayList(RemoveToken);
Collections.sort(flist,new OffsetComparator());
for(Iterator occuranceIterator = flist.iterator();occuranceIterator.hasNext();)
{
Annotation occuranceAnn = (Annotation)occuranceIterator.next();
gate.FeatureMap features = occuranceAnn.getFeatures();
outputAS.add(occuranceAnn.getStartNode(),occuranceAnn.getEndNode(),"RemoveToken",features);
}
}
}
}

Phase: ALKTokenRemove
Input: Token
Options: control = appelt

Rule: endline
(
(({Token.string ==~ "(?i)alk"})|({Token.string ==~ "(?i)Alkaline"}))
({Token.string == "."})?
(({Token.string ==~ "(?i)Phosph"})|({Token.string ==~ "(?i)Phos"})|({Token.string ==~ "(?i)Phosphatase"})|({Token.string ==~ "(?i)Phospate"}))
):line

-->
:line.RemoveToken = {Rule = "endline"}

Rule: removePR
(
(({Token.string == "("})|({Token.string == "PR"})|({Token.string == ")"}))
):line

-->
:line.RemoveToken = {Rule = "endline"}

Phase: SectionEnd1234
Input: RemoveToken
Options: control = appelt
Rule: removebreakline
(
{RemoveToken}
):fh
-->
{
AnnotationSet tdset = (AnnotationSet)bindings.get("fh");
if(tdset != null){
AnnotationSet totalset = inputAS.getContained(tdset.firstNode().getOffset(),tdset.lastNode().getOffset());
AnnotationSet RemoveToken = totalset.get("RemoveToken");
inputAS.removeAll(totalset);
if (RemoveToken != null && !RemoveToken.isEmpty()){
ArrayList flist = new ArrayList(RemoveToken);
Collections.sort(flist,new OffsetComparator());
for(Iterator occuranceIterator = flist.iterator();occuranceIterator.hasNext();)
{
Annotation occuranceAnn = (Annotation)occuranceIterator.next();
gate.FeatureMap features = occuranceAnn.getFeatures();
outputAS.add(occuranceAnn.getStartNode(),occuranceAnn.getEndNode(),"RemoveToken",features);
}
}
}
}

Phase: EOL
Input: SpaceToken
Options: control = appelt

Rule: endline
(
({SpaceToken.kind == "control"}):line
)
-->
:line.EndOfLine = {Rule = "endline"}


Phase: Split
Input: Split
Options: control = appelt

Rule: SEnd
(  
{Split.kind == "external"}
):end
-->  
:end.SectionEnd = {rule = "SEnd"}

Rule: SenEnd
(  
{Split.kind == "internal"}
):send
-->  
:send.SentEnd = {rule = "SenEnd"}

/*isCancer*/
Phase: SectionHeading
Input: Lookup
Options: control = appelt

Rule: Ca
(
{Lookup.majorType == "cancer"}
):Heading
-->
:Heading.Ca = {Rule = "Ca", Text = :Heading@cleanString}

/*Indications*/

Phase: CoomaEnd
Input: Token
Options: control = appelt

Rule: Comma
(
({Token.string == ","}):line
)
-->
:line.Comma = {Rule = "Comma"}

Rule: SickleCell
(
({Token.string ==~ "(?i)Sickle"}{Token.string ==~ "(?i)Cell"}{Token.string ==~ "(?i)Disease"}):line
)
-->
:line.Disease1 = {Rule = "SickleCell", Text = :line@cleanString}

Rule: myelodysplastic
(
({Token.string ==~ "(?i)myelodysplastic"}({Token.string ==~ "(?i)syndrome"}|{Token.string ==~ "(?i)syndromes"})):line
)
-->
:line.Disease1 = {Rule = "myelodysplastic", Text = :line@cleanString}

